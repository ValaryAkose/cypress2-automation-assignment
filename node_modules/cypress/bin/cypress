// // CYPRESS ASSERTIONS PRACTICE


// // be.visible
// // NOTE: Verifies that an element is physically visible on the webpage screen.
// cy.get('#welcome-banner').should('be.visible')


// // exist
// // NOTE: Verifies that an element is present in the HTML DOM code, even if it is hidden from view.
// cy.get('.modal-overlay').should('exist')


// // contain
// // NOTE: Verifies that an element's text includes a specific partial text substring.
// cy.get('.success-message').should('contain', 'Saved successfully')


// // have.text
// // NOTE: Verifies that an element's text matches a specific exact string completely.
// cy.get('h1.page-title').should('have.text', 'Dashboard Overview')


// // have.value
// // NOTE: Verifies that an input field, textbox, or dropdown currently holds a specific text value.
// cy.get('input[type="email"]').should('have.value', 'user@example.com')


// // have.length
// // NOTE: Verifies the exact number of matching elements found in a collection (like table rows or list items).
// cy.get('.todo-list li').should('have.length', 5)


// // be.enabled
// // NOTE: Verifies that an interactive element (like a button or input) is active and can be clicked or typed into.
// cy.get('#submit-btn').should('be.enabled')


// // be.disabled
// // NOTE: Verifies that an interactive element is locked and cannot be clicked or modified by the user.
// cy.get('#cancelled-input').should('be.disabled')


// // be.checked
// // NOTE: Verifies that a checkbox or radio button element is currently selected.
// cy.get('#agree-terms-checkbox').should('be.checked')


// // have.attr
// // NOTE: Verifies that an HTML element possesses a specific attribute, and optionally checks its value (like an image src or a link href).
// cy.get('a.profile-link').should('have.attr', 'href', '/profile-settings')





// // CYPRESS LOCATOR EXAMPLES


// // cy.get()
// // NOTE: Finds an element globally anywhere on the page using its CSS selector.
// cy.get('#submit-button').click()


// // cy.contains()
// // NOTE: Finds an element based on the visible text it displays to the user.
// cy.contains('Log In').click()


// // .find()
// // NOTE: Searches deep inside a previously located parent container to find a specific child element.
// cy.get('#login-form').find('input[type="email"]').type('user@test.com')


// // .children()
// // NOTE: Grabs all immediate child elements that sit exactly one level below the selected element.
// cy.get('ul.nav-menu').children().should('have.length.at.least', 1)


// // .parent()
// // NOTE: Moves exactly one structural layer upward to target the immediate wrapper or container element.
// cy.get('span.close-icon').parent().click()


// // .closest()
// // NOTE: Traverses upward through parent containers to find the nearest ancestor matching the selector.
// cy.get('.delete-btn').closest('.user-row-container').should('have.class', 'active')


// // .eq()
// // NOTE: Chooses a single element out of a matching collection based on its index position (starts at 0).
// cy.get('table tbody tr').eq(2).should('contain', 'Third Row Data')


// // .first()
// // NOTE: Isolates and targets the very first item out of a collection of matching elements.
// cy.get('.product-card').first().click()


// // .last()
// // NOTE: Isolates and targets the final, last item out of a collection of matching elements.
